{{ form_start(form) }}
<div class="form-form">
    <div class="flex gap-2 items-center">
        {{ form_widget(form.name , {
        'attr': {
        'placeholder': 'Ex : Urgente',
        'class': 'form-input'
        }
        }) }}
        <button class="btn black-btn"><i class="fa-solid fa-plus"></i></button>
    </div>
    <p>{{ form_errors(form.name) }}</p>
    
    <div class="flex flex-col gap-3">
        {%for priority in priorities %}
        <div class="flex gap-2 items-center w-full justify-between px-2 py-1 border border-(--secondary-color) rounded">
            <span>{{ priority.name }}</span>
            <a href="{{ path('app_priority_delete', {'id': priority.id}) }}" class="btn red-btn"><i
                    class="fa-solid fa-trash"></i></a>
        </div>
        {% endfor %}
    </div>

</div>

{{ form_end(form) }}